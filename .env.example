# Базовая модель Hugging Face (должна совпадать с обучением)
BASE_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
BASE_MODEL_REVISION=main

# Путь к LoRA-адаптеру (каталог с adapter_config.json и весами).
# Если пусто: сначала fine_tuned_model/, затем adapters/qwen2.5-1.5b-json-lora
ADAPTER_PATH=

# Опционально: системный промпт в chat template
SYSTEM_PROMPT=

# Декодирование
MAX_NEW_TOKENS=160
TEMPERATURE=0.1
TOP_P=0.9
DO_SAMPLE=false

# Лимит длины промпта после trim (символы)
MAX_PROMPT_CHARS=2048
